# ============================================================
# STEP 3: FEATURE ENGINEERING - AGE (USING MEAN OF RANGE)
# ============================================================

def extract_age_mean(age_str):
    """
    Extract mean age from SEER age format.
    Examples:
    - "00 years" → 0
    - "01-04 years" → (1+4)/2 = 2.5
    - "85-89 years" → (85+89)/2 = 87
    - "90+ years" → 92 (assuming mean of 90-95)
    """
    if pd.isna(age_str):
        return np.nan
    
    age_str = str(age_str).strip()
    
    # Handle special cases
    if '90+' in age_str or '90 years' in age_str:
        return 92  # Assume mean of 90-95
    if '<1' in age_str or '00 years' in age_str:
        return 0.5  # Assume mean of 0-1
    
    try:
        import re
        # Extract all numbers from the string
        numbers = re.findall(r'\d+', age_str)
        
        if len(numbers) == 0:
            return np.nan
        elif len(numbers) == 1:
            # Single age value
            return float(numbers[0])
        else:
            # Range of ages - take the mean
            ages = [float(num) for num in numbers]
            return np.mean(ages)
    except:
        return np.nan

# Apply the function
