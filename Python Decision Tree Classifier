        df.loc[mask, col + '_Scaled'] = scaler.fit_transform(df.loc[mask, [col]])
        # NaN values will remain NaN in the scaled column
        df.loc[~mask, col + '_Scaled'] = np.nan
    else:
        df[col + '_Scaled'] = np.nan
    
    print(f"\n{col}_Scaled - Missing values preserved: {df[col + '_Scaled'].isna().sum()}")

