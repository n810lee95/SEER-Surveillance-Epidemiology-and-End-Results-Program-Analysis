def extract_survival_months(months_str):
    """Extract numeric survival months from SEER format"""
    if pd.isna(months_str) or 'NULL' in str(months_str) or 'Unknown' in str(months_str):
        return np.nan
    try:
        import re
        numbers = re.findall(r'\d+', str(months_str))
        if numbers:
            return int(numbers[0])
        return np.nan
    except:
        return np.nan

