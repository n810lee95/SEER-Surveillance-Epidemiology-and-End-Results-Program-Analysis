# ============================================================
# STEP 4: FEATURE ENGINEERING - AGE
# ============================================================

print("\n" + "="*60)
print("STEP 4: FEATURE ENGINEERING - AGE")
print("="*60)

def extract_age_mean(age_str):
    if pd.isna(age_str):
        return np.nan
    age_str = str(age_str).strip()
    if '90+' in age_str or '90 years' in age_str:
        return 92
    if '<1' in age_str or '00 years' in age_str:
        return 0.5
    try:
        import re
        numbers = re.findall(r'\d+', age_str)
        if len(numbers) == 0:
            return np.nan
        elif len(numbers) == 1:
            return float(numbers[0])
        else:
            return np.mean([float(n) for n in numbers])
    except:
        return np.nan

df['Age_Mean'] = df['Age recode with <1 year olds and 90+'].apply(extract_age_mean)
print(f"Age_Mean created: {df['Age_Mean'].notna().sum()} non-null values")

# ============================================================
# STEP 5: FEATURE ENGINEERING - TUMOR SIZE
# ============================================================

print("\n" + "="*60)
print("STEP 5: FEATURE ENGINEERING - TUMOR SIZE")
print("="*60)

def extract_tumor_size(size_str):
    if pd.isna(size_str) or 'Unknown' in str(size_str) or 'NULL' in str(size_str):
        return np.nan
    try:
        import re
        numbers = re.findall(r'\d+', str(size_str))
        if numbers:
            return float(numbers[0])
        return np.nan
    except:
        return np.nan

df['Tumor_Size_mm'] = df['Tumor Size Over Time Recode (1988+) with NULL'].apply(extract_tumor_size)
print(f"Tumor_Size_mm created: {df['Tumor_Size_mm'].notna().sum()} non-null values")

# ============================================================
# STEP 6: FEATURE ENGINEERING - TREATMENT DAYS
# ============================================================

print("\n" + "="*60)
print("STEP 6: FEATURE ENGINEERING - TREATMENT DAYS")
print("="*60)

def extract_treatment_days(days_str):
    if pd.isna(days_str) or 'NULL' in str(days_str) or 'Unknown' in str(days_str):
        return np.nan
    try:
        import re
        numbers = re.findall(r'\d+', str(days_str))
        if numbers:
            return int(numbers[0])
        return np.nan
    except:
        return np.nan

df['Treatment_Days'] = df['Time from diagnosis to treatment in days recode with NULL'].apply(extract_treatment_days)
print(f"Treatment_Days created: {df['Treatment_Days'].notna().sum()} non-null values")

# ============================================================
# STEP 7: ENCODE CATEGORICAL VARIABLES
# ============================================================

print("\n" + "="*60)
print("STEP 7: ENCODING CATEGORICAL VARIABLES")
print("="*60)

categorical_cols = [
    'Sex',
    'Marital status at diagnosis',
    'SEER historic stage A (1973-2015)',
    'Derived Summary Grade 2018 (2018+) with NULL',
    'RX Summ--Surg Prim Site (1998+)',
    'COD to site recode ICD-O-3 2023 Revision Expanded (1999+)'
]

for col in categorical_cols:
    if col in df.columns:
        df.loc[:, col] = df[col].fillna('Unknown')
        le = LabelEncoder()
        df[col + '_Encoded'] = le.fit_transform(df[col].astype(str))
        print(f"  Encoded {col}: {df[col].nunique()} unique values")

# ============================================================
# STEP 8: FILL MISSING NUMERIC VALUES WITH MEDIAN
# ============================================================
# Reverted from row-dropping (v2) — dropping removed 45% of patients,
# which is too large a loss given that missingness is largely in
# Tumor_Size_mm and Treatment_Days, not random.

print("\n" + "="*60)
print("STEP 8: FILLING MISSING VALUES WITH MEDIAN")
print("="*60)

numeric_features = ['Age_Mean', 'Tumor_Size_mm', 'Treatment_Days']

for col in numeric_features:
    median_val = df[col].median()
    missing_count = df[col].isna().sum()
    df.loc[:, col] = df[col].fillna(median_val)
    print(f"  Filled {missing_count} missing values in {col} with median: {median_val:.2f}")

# ============================================================
# STEP 9: STANDARDIZE NUMERIC FEATURES
# ============================================================

print("\n" + "="*60)
print("STEP 9: STANDARDIZING NUMERIC FEATURES")
print("="*60)

scaler = StandardScaler()

df[['Age_Mean']] = scaler.fit_transform(df[['Age_Mean']])
df[['Tumor_Size_mm']] = scaler.fit_transform(df[['Tumor_Size_mm']])
df[['Treatment_Days']] = scaler.fit_transform(df[['Treatment_Days']])

print("  Age_Mean, Tumor_Size_mm, Treatment_Days standardized (mean=0, std=1)")

# ============================================================
# STEP 10: SAVE PATIENT IDs
# ============================================================

print("\n" + "="*60)
print("STEP 10: SAVING PATIENT IDs")
print("="*60)

patient_ids = df['Patient ID'].copy()
print(f"  Patient IDs saved: {len(patient_ids)}")

