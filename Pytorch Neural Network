# ============================================================
# STEP 12: SELECT FEATURES AND TARGETS
# ============================================================

print("\n" + "="*60)
print("STEP 12: SELECTING FEATURES AND TARGETS")
print("="*60)

feature_columns = [
    'Age_Mean',
    'Tumor_Size_mm',
    'Treatment_Days',
    'Year of diagnosis',
    'Sex_Encoded',
    'Marital status at diagnosis_Encoded',
    'SEER historic stage A (1973-2015)_Encoded',
    'Derived Summary Grade 2018 (2018+) with NULL_Encoded',
    'RX Summ--Surg Prim Site (1998+)_Encoded',
    'COD to site recode ICD-O-3 2023 Revision Expanded (1999+)_Encoded'
]

X = df[feature_columns].copy()
y_log = df['Survival_Months_Log'].copy()
y_original = df['Survival_Months_Original'].copy()

print(f"Features (X): {X.shape[0]} patients, {X.shape[1]} features")
missing = X.isnull().sum()
print(f"\nMissing values in features:")
if missing.sum() > 0:
    print(missing[missing > 0])
else:
    print("  None - All features are complete!")

# ============================================================
# STEP 12b: APPLY DT IMPORTANCE WEIGHTS TO NN INPUT FEATURES
# ============================================================
# IMPORTANT: This weighted copy (X_nn) is used ONLY for the neural
# network. The RSF receives the original unweighted X to avoid
# distorting its internal distance/splitting calculations.
#
# Weights are the full-precision feature importances from the
# trained Decision Tree Regressor (dt_model.feature_importances_),
# retrieved directly from VS Code — not approximated from a chart.
#
# Feature names here match the NN feature_columns list (Step 12),
# which uses standardized names without the _Scaled suffix.
# The DT used _Scaled suffixes internally but the importance values
# are identical — only the column name reference differs.
#
# Weights are scaled relative to the mean importance (mean = 1.0),
# then sqrt() is applied to compress extreme values and prevent
# Year of diagnosis (~5.3x raw) from collapsing gradients.

print("\n" + "="*60)
print("STEP 12b: APPLYING DT IMPORTANCE WEIGHTS TO NN FEATURES")
print("="*60)

# Full-precision importances from dt_model.feature_importances_
# (Decision Tree Regressor, random_state=31, trained on 865,036 patients)
dt_importance_raw = {
    'Year of diagnosis':                                                    0.5429334697239565,
    'COD to site recode ICD-O-3 2023 Revision Expanded (1999+)_Encoded':   0.3075706737782824,
    'RX Summ--Surg Prim Site (1998+)_Encoded':                             0.07825188568694544,
    'SEER historic stage A (1973-2015)_Encoded':                           0.027238293856897022,
    'Treatment_Days':                                                       0.013731478467679865,
    'Derived Summary Grade 2018 (2018+) with NULL_Encoded':                0.011505179855461095,
    'Age_Mean':                                                             0.008133341640781075,
    'Tumor_Size_mm':                                                        0.007543539540160894,
    'Sex_Encoded':                                                          0.0025086730294923702,
    'Marital status at diagnosis_Encoded':                                  0.0005834644203433181,
}

# Alias so downstream code is unchanged
rsf_importance_raw = dt_importance_raw

# Scale relative to mean, then apply sqrt to compress extreme values
mean_importance = sum(rsf_importance_raw.values()) / len(rsf_importance_raw)
rsf_importance_scaled = {
    k: np.sqrt(v / mean_importance)
    for k, v in rsf_importance_raw.items()
}

print("  Sqrt-scaled importance weights (sqrt of mean-relative score):")
for feat, weight in sorted(rsf_importance_scaled.items(), key=lambda x: -x[1]):
    print(f"    {feat:<65s} {weight:.4f}")

# Cast to float64, then apply weights — NN only
X_nn = X.copy().astype(np.float64)
for col in feature_columns:
    weight = rsf_importance_scaled.get(col, 1.0)
    X_nn.loc[:, col] = X_nn[col] * weight

print(f"\n  ✓ Weighted feature matrix (X_nn) created for neural network")
print(f"  ✓ Original feature matrix (X) preserved for Random Survival Forest")

# ============================================================
# STEP 13: TRAIN-TEST SPLIT
# ============================================================

print("\n" + "="*60)
print("STEP 13: TRAIN-TEST SPLIT")
print("="*60)

# Split both weighted (NN) and unweighted (RSF) feature matrices
# using the same random_state so train/test sets are identical
(X_nn_train, X_nn_test,
 X_rsf_train, X_rsf_test,
 y_train_log, y_test_log,
 y_train_orig, y_test_orig) = train_test_split(
    X_nn, X, y_log, y_original,
    test_size=0.2,
    random_state=31
)

_, patient_ids_test, _, _ = train_test_split(
    patient_ids, y_log,
    test_size=0.2,
    random_state=31
)

print(f"Training set: {len(X_nn_train)} patients ({len(X_nn_train)/len(X)*100:.1f}%)")
print(f"Test set: {len(X_nn_test)} patients ({len(X_nn_test)/len(X)*100:.1f}%)")

# ============================================================
# STEP 14: CONVERT TO PYTORCH TENSORS
# ============================================================

print("\n" + "="*60)
print("STEP 14: CONVERTING TO PYTORCH TENSORS")
print("="*60)

features_np      = X_nn_train.values.astype(np.float32)
target_np        = y_train_log.values.astype(np.float32).reshape(-1, 1)
features_tensor  = torch.from_numpy(features_np).float()
target_tensor    = torch.from_numpy(target_np).float()

test_features_np     = X_nn_test.values.astype(np.float32)
test_target_np       = y_test_log.values.astype(np.float32).reshape(-1, 1)
test_tensor          = torch.from_numpy(test_features_np).float()
test_target_tensor   = torch.from_numpy(test_target_np).float()

input_size = features_tensor.shape[1]

print(f"Features tensor shape: {features_tensor.shape}")
print(f"Target tensor shape: {target_tensor.shape}")
print(f"Input size for neural network: {input_size} features")

# ============================================================
# STEP 15: BUILD NEURAL NETWORK MODEL
# ============================================================

print("\n" + "="*60)
print("STEP 15: BUILDING NEURAL NETWORK")
print("="*60)

survival_model = nn.Sequential(
    nn.Linear(input_size, 128),
    nn.BatchNorm1d(128),
    nn.ReLU(),
    nn.Dropout(0.3),

    nn.Linear(128, 64),
    nn.BatchNorm1d(64),
    nn.ReLU(),
    nn.Dropout(0.3),

    nn.Linear(64, 32),
    nn.BatchNorm1d(32),
    nn.ReLU(),
    nn.Dropout(0.2),

    nn.Linear(32, 16),
    nn.ReLU(),

    nn.Linear(16, 1)
)

print("Neural Network Architecture:")
print(survival_model)
print(f"\nTotal parameters: {sum(p.numel() for p in survival_model.parameters()):,}")

# ============================================================
# STEP 16: DEFINE LOSS FUNCTION AND OPTIMIZER
# ============================================================

print("\n" + "="*60)
print("STEP 16: DEFINING LOSS AND OPTIMIZER")
print("="*60)

criterion  = nn.HuberLoss(delta=1.0)
optimizer  = torch.optim.Adam(survival_model.parameters(), lr=0.001)
scheduler  = torch.optim.lr_scheduler.ReduceLROnPlateau(
    optimizer, mode='min', patience=20, factor=0.5
)

print("Loss function: HuberLoss (delta=1.0)")
print("Optimizer: Adam (lr=0.001)")
print("Scheduler: ReduceLROnPlateau (patience=20, factor=0.5)")

# ============================================================
# STEP 17: TRAINING LOOP
# ============================================================

print("\n" + "="*60)
print("STEP 17: TRAINING NEURAL NETWORK")
print("="*60)

num_epochs = 500
print(f"Epochs: {num_epochs}\n")

train_losses = []
test_losses  = []

for epoch in range(num_epochs):
    survival_model.train()
    predictions = survival_model(features_tensor)
    loss = criterion(predictions, target_tensor)

    if torch.isnan(loss):
        print(f"\n❌ NaN detected at epoch {epoch+1}! Stopping.")
        break

    train_losses.append(loss.item())
    optimizer.zero_grad()
    loss.backward()
    torch.nn.utils.clip_grad_norm_(survival_model.parameters(), max_norm=1.0)
    optimizer.step()

    if (epoch + 1) % 50 == 0:
        survival_model.eval()
        with torch.no_grad():
            test_pred = survival_model(test_tensor)
            test_loss = criterion(test_pred, test_target_tensor)
            test_losses.append(test_loss.item())
        scheduler.step(test_loss)
        current_lr = optimizer.param_groups[0]['lr']
        print(f'Epoch [{epoch+1}/{num_epochs}]  Train Loss: {loss.item():.6f}  '
              f'Test Loss: {test_loss.item():.6f}  LR: {current_lr:.6f}')

print("\n✓ Training complete!")

# ============================================================
# STEP 18: PLOT TRAINING LOSS
# ============================================================

plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)
plt.plot(train_losses, color='blue', linewidth=1, alpha=0.7)
plt.xlabel('Epoch', fontsize=12)
plt.ylabel('Training Loss (Huber)', fontsize=12)
plt.title('Training Loss Over Time', fontsize=14, fontweight='bold')
plt.grid(True, alpha=0.3)

plt.subplot(1, 2, 2)
test_epochs = np.arange(50, len(test_losses)*50 + 1, 50)
plt.plot(test_epochs, test_losses, color='red', marker='o', linewidth=2, markersize=3)
plt.xlabel('Epoch', fontsize=12)
plt.ylabel('Test Loss (Huber)', fontsize=12)
plt.title('Test Loss Over Time', fontsize=14, fontweight='bold')
plt.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('training_loss_curve_log.png', dpi=300, bbox_inches='tight')
plt.close()
print("✓ Saved: training_loss_curve_log.png")

# ============================================================
# STEP 19: MAKE PREDICTIONS (LOG SCALE)
# ============================================================

print("\n" + "="*60)
print("STEP 19: MAKING PREDICTIONS")
print("="*60)

survival_model.eval()
with torch.no_grad():
    test_predictions_log  = survival_model(test_tensor).numpy().flatten()
    train_predictions_log = survival_model(features_tensor).numpy().flatten()

unique_log_preds = len(np.unique(np.round(test_predictions_log, 3)))
print(f"  Unique log-scale predictions: {unique_log_preds}")
if unique_log_preds < 10:
    print("  ⚠️ Warning: Nearly constant predictions — model may not have converged")
else:
    print("  ✓ Predictions vary as expected")

# ============================================================
# STEP 20: TRANSFORM BACK TO ORIGINAL SCALE
# ============================================================

print("\n" + "="*60)
print("STEP 20: TRANSFORMING BACK TO ORIGINAL SCALE")
print("="*60)

test_predictions  = np.expm1(test_predictions_log)
train_predictions = np.expm1(train_predictions_log)

print(f"Predicted survival (months): min={test_predictions.min():.2f}  "
      f"max={test_predictions.max():.2f}  mean={test_predictions.mean():.2f}  "
      f"median={np.median(test_predictions):.2f}")
print(f"Actual survival (months):    min={y_test_orig.min():.2f}  "
      f"max={y_test_orig.max():.2f}  mean={y_test_orig.mean():.2f}  "
      f"median={y_test_orig.median():.2f}")

# ============================================================
# STEP 21: EVALUATE NEURAL NETWORK PERFORMANCE
# ============================================================

print("\n" + "="*60)
print("STEP 21: EVALUATING NEURAL NETWORK PERFORMANCE")
print("="*60)

y_test  = y_test_orig.values
y_train = y_train_orig.values

test_rmse  = np.sqrt(mean_squared_error(y_test, test_predictions))
test_mae   = mean_absolute_error(y_test, test_predictions)
test_r2    = r2_score(y_test, test_predictions)
train_rmse = np.sqrt(mean_squared_error(y_train, train_predictions))
train_mae  = mean_absolute_error(y_train, train_predictions)
train_r2   = r2_score(y_train, train_predictions)

print(f"\n📊 Test Set:   RMSE={test_rmse:.2f}  MAE={test_mae:.2f}  R²={test_r2:.3f}")
print(f"📊 Train Set:  RMSE={train_rmse:.2f}  MAE={train_mae:.2f}  R²={train_r2:.3f}")
print(f"\n🔍 Overfitting (train R² - test R²): {train_r2 - test_r2:.3f}")

if test_r2 > 0.3:
    print(f"✓ Good: model explains {test_r2*100:.1f}% of variance")
elif test_r2 > 0.1:
    print(f"⚠️ Moderate: R²={test_r2:.3f}, room for improvement")
else:
    print(f"❌ Poor: R²={test_r2:.3f}")

# ============================================================
# STEPS 22-24: VISUALIZATIONS
# ============================================================

# Actual vs Predicted
plt.figure(figsize=(10, 6))
plt.scatter(y_test, test_predictions, alpha=0.3, s=10, color='steelblue', edgecolors='none')
plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'r--', lw=2, label='Perfect Prediction')
plt.xlabel('Actual Survival Months', fontsize=13)
plt.ylabel('Predicted Survival Months', fontsize=13)
plt.title(f'Neural Network: Actual vs Predicted\nR²={test_r2:.3f}  RMSE={test_rmse:.2f} months', fontsize=14, fontweight='bold')
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('nn_actual_vs_predicted_log.png', dpi=300, bbox_inches='tight')
plt.close()
print("✓ Saved: nn_actual_vs_predicted_log.png")

# Residuals
residuals = y_test - test_predictions
plt.figure(figsize=(10, 6))
plt.scatter(test_predictions, residuals, alpha=0.3, s=10, color='coral', edgecolors='none')
plt.axhline(y=0, color='red', linestyle='--', lw=2)
plt.xlabel('Predicted Survival Months', fontsize=13)
plt.ylabel('Residuals (Actual - Predicted)', fontsize=13)
