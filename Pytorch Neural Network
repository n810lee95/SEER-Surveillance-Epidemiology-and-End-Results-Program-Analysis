plt.title(f'Original Distribution\nSkewness = {df["Survival_Months_Original"].skew():.2f}', fontsize=14, fontweight='bold')
plt.axvline(df['Survival_Months_Original'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean = {df["Survival_Months_Original"].mean():.1f}')
plt.axvline(df['Survival_Months_Original'].median(), color='orange', linestyle='--', linewidth=2, label=f'Median = {df["Survival_Months_Original"].median():.1f}')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(1, 2, 2)
plt.hist(df['Survival_Months_Log'], bins=100, color='green', alpha=0.7, edgecolor='black')
plt.xlabel('Survival Months (Log Transformed)', fontsize=12)
plt.ylabel('Frequency', fontsize=12)
plt.title(f'Log-Transformed Distribution\nSkewness = {df["Survival_Months_Log"].skew():.2f}', fontsize=14, fontweight='bold')
plt.axvline(df['Survival_Months_Log'].mean(), color='red', linestyle='--', linewidth=2, label=f'Mean = {df["Survival_Months_Log"].mean():.2f}')
plt.axvline(df['Survival_Months_Log'].median(), color='orange', linestyle='--', linewidth=2, label=f'Median = {df["Survival_Months_Log"].median():.2f}')
plt.legend()
plt.grid(True, alpha=0.3)

