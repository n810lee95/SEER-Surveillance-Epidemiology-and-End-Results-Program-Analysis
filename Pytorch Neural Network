# STEP 11: LOG TRANSFORM TARGET VARIABLE
# ============================================================

print("\n" + "="*60)
print("STEP 11: LOG TRANSFORMING TARGET VARIABLE")
print("="*60)

df['Survival_Months_Original'] = df['Survival_Months_Numeric'].copy()
df['Survival_Months_Log'] = np.log1p(df['Survival_Months_Numeric'])

print(f"Original Survival:")
print(f"  Mean: {df['Survival_Months_Original'].mean():.2f} months")
print(f"  Median: {df['Survival_Months_Original'].median():.2f} months")
print(f"  Std: {df['Survival_Months_Original'].std():.2f} months")
print(f"  Skewness: {df['Survival_Months_Original'].skew():.2f}")

print(f"\nLog-Transformed Survival:")
print(f"  Mean: {df['Survival_Months_Log'].mean():.3f}")
print(f"  Median: {df['Survival_Months_Log'].median():.3f}")
print(f"  Std: {df['Survival_Months_Log'].std():.3f}")
print(f"  Skewness: {df['Survival_Months_Log'].skew():.2f}")

plt.figure(figsize=(14, 5))

plt.subplot(1, 2, 1)
plt.hist(df['Survival_Months_Original'], bins=100, color='blue', alpha=0.7, edgecolor='black')
plt.xlabel('Survival Months (Original)', fontsize=12)
